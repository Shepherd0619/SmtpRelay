{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SmtpRelay": {
    "SmtpServer": {
      "Enabled": true,
      "Port": 25,
      "HostName": "smtp-relay.local",
      "MaxMessageSizeMB": 25,
      "RequireAuthentication": false,
      "AllowedRecipientDomains": "*",
      "Auth": {
        "Username": "",
        "Password": ""
      }
    },
    "GraphApi": {
      "Enabled": false,
      "TenantId": "",
      "ClientId": "",
      "ClientSecret": "",
      "UserId": "",
      "SaveToSentItems": true,
      "CreateDraftsBeforeSending": true
    },
    "SmtpOutput": {
      "Enabled": false,
      "Host": "localhost",
      "Port": 587,
      "UseSsl": true,
      "Username": "",
      "Password": "",
      "FromAddress": ""
    },
    "WebhookOutput": {
      "Enabled": false,
      "Targets": []
    },
    "WebhookInput": {
      "Enabled": true,
      "ApiKey": ""
    },
    "Queue": {
      "DatabasePath": "Data/queue.db",
      "MaxRetryCount": 5,
      "RetryDelaySeconds": 60,
      "ProcessingIntervalSeconds": 5,
      "MaxConcurrentProcessing": 1,
      "RetentionDays": 7
    }
  }
}